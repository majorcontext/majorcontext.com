---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../lib/products';
---

<BaseLayout
  title="Major Context"
  description="Safe infrastructure for AI agents. Sandboxed execution, credential injection, policy enforcement, and audit logging."
>
  <div class="min-h-screen flex flex-col items-center px-4 py-16 md:py-24">
    <div class="max-w-2xl w-full">
      <!-- Logo -->
      <div class="mb-8 text-center">
        <img src="/logo.svg" alt="Major Context" class="w-24 h-24 mx-auto" />
      </div>

      <!-- Title -->
      <h1 class="font-serif text-4xl md:text-5xl font-normal leading-tight tracking-tight mb-4 text-stone-800 dark:text-stone-300 text-center">
        Major Context
      </h1>

      <!-- Subtitle -->
      <p class="text-lg text-stone-600 dark:text-stone-400 mb-16 leading-relaxed text-center">
        Safe infrastructure for AI agents
      </p>

      <!-- Product Cards -->
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        <!-- Moat -->
        <a href="/moat" class="group block border border-stone-300 dark:border-stone-700 p-6 hover:border-sky-600 dark:hover:border-sky-500 transition-colors">
          <div class="mb-3">
            <h2 class="text-sm font-bold tracking-[0.15em] text-stone-800 dark:text-stone-300">MOAT</h2>
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed mb-4">
            {products.moat.tagline}. Sandboxed containers, network-layer credential injection, and tamper-proof audit trails.
          </p>
          <span class="text-sm text-sky-700 dark:text-sky-400 group-hover:text-sky-800 dark:group-hover:text-sky-300">
            View documentation →
          </span>
        </a>

        <!-- Keep -->
        <a href="/keep" class="group block border border-stone-300 dark:border-stone-700 p-6 hover:border-amber-600 dark:hover:border-amber-500 transition-colors">
          <div class="flex items-center gap-2 mb-3">
            <h2 class="text-sm font-bold tracking-[0.15em] text-stone-800 dark:text-stone-300">KEEP</h2>
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed mb-4">
            {products.keep.tagline}. Declarative rules that deny, redact, or log tool calls. Works standalone or with Moat.
          </p>
          <span class="text-sm text-amber-700 dark:text-amber-400 group-hover:text-amber-800 dark:group-hover:text-amber-300">
            View documentation →
          </span>
        </a>
      </div>

      <!-- Who Did It -->
      <div class="mb-16">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-stone-600 dark:text-stone-400 pb-3 mb-4 border-b border-stone-300 dark:border-stone-700">Who Did It</h2>

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div>
            <h3 class="text-sm font-semibold text-stone-800 dark:text-stone-300 mb-1">
              <a href="https://pupius.com" class="text-sky-700 dark:text-sky-400 hover:text-sky-800 dark:hover:text-sky-300" target="_blank" rel="noopener noreferrer">
                Dan Pupius
              </a>
            </h3>
            <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed">
              Principal Engineer at TheGP, helping startups at critical moments, while exploring what it means to be AI native.
            </p>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-stone-800 dark:text-stone-300 mb-1">
              <a href="https://andybons.com" class="text-sky-700 dark:text-sky-400 hover:text-sky-800 dark:hover:text-sky-300" target="_blank" rel="noopener noreferrer">
                Andy Bonventre
              </a>
            </h3>
            <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed">
              CTO at Neptune. Previously led the Go open source project and security for Stripe Link.
            </p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="pt-8 border-t border-stone-300 dark:border-stone-700">
        <p class="text-sm text-stone-600 dark:text-stone-400 text-center">
          <a href="https://github.com/majorcontext/moat" class="text-sky-700 dark:text-sky-400 hover:text-sky-800 dark:hover:text-sky-300 underline">moat</a>
          {' · '}
          <a href="https://github.com/majorcontext/keep" class="text-sky-700 dark:text-sky-400 hover:text-sky-800 dark:hover:text-sky-300 underline">keep</a>
          {' · '}
          <a href="https://github.com/majorcontext" class="text-sky-700 dark:text-sky-400 hover:text-sky-800 dark:hover:text-sky-300 underline">github.com/majorcontext</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
